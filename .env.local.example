# Copy to .env.local for local dev
NEXT_PUBLIC_API_URL=http://localhost:8081

# Google OAuth — same Client ID for frontend and backend
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Official contact / outbound-from address shown to users (default: contact@expenseit.co.in)
NEXT_PUBLIC_CONTACT_EMAIL=contact@expenseit.co.in

# Razorpay (Test mode keys from https://dashboard.razorpay.com/app/keys)
# Leave empty for mock payments in local dev (BILLING_MOCK_PAYMENTS=true on backend)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
